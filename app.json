{
  "expo": {
    "name": "CryptoLens",
    "slug": "cryptolens",
    "version": "0.2.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "cryptolens",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.zedxihan.cryptolens"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#060c0a"
      },
      "package": "com.zedxihan.cryptolens",
      "versionCode": 2,
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 250,
          "resizeMode": "contain",
          "backgroundColor": "#060c0a",
          "dark": {
            "backgroundColor": "#060c0a"
          }
        }
      ],
      "expo-font",
      "expo-image",
      "expo-web-browser",
      "./plugins/withSeparateBuilds"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8a785b78-ed20-4fea-9d2a-f17dc0e3770f"
      }
    },
    "owner": "cryptolens-org"
  }
}
